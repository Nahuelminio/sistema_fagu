# ── ARCA (ex-AFIP) — Facturación electrónica ──────────────────────────────
#
# Pasos para activar:
# 1. Poner certificate.pem y privatekey.pem en la carpeta server/certs/
# 2. Copiar estas variables a tu .env (Railway → Variables de entorno)
# 3. Cambiar ARCA_ENABLED a true
#

ARCA_ENABLED=false

# CUIT del negocio (sin guiones)
ARCA_CUIT=20123456789

# Número de punto de venta habilitado en ARCA
ARCA_PUNTO_VENTA=1

# Tipo de comprobante:
# 11 = Factura C (Monotributista)
#  6 = Factura B (Responsable Inscripto → Consumidor Final)
ARCA_CBTE_TIPO=11

# false = ambiente de pruebas (homologación), true = producción real
ARCA_PRODUCTION=false

# ── Resend — Envío de emails ───────────────────────────────────────────────
# Crear cuenta en resend.com, generar API Key y pegar acá
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Dominio verificado en Resend (mientras desarrollás usá onboarding@resend.dev)
RESEND_FROM=FAGU Drink Bar <facturas@tudominio.com>
