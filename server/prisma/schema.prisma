generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

enum Role {
  ADMIN
  USER
}

enum MovementType {
  INGRESO
  SALIDA
  AJUSTE
}

enum PaymentMethod {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  MERCADOPAGO
  CUENTA_CORRIENTE
}

model User {
  id        Int             @id @default(autoincrement())
  email     String          @unique
  name      String
  password  String
  role      Role            @default(USER)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  movements StockMovement[]
  sales     Sale[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id               Int             @id @default(autoincrement())
  name             String
  categoryId       Int
  category         Category        @relation(fields: [categoryId], references: [id])
  unit             String
  currentStock     Decimal         @default(0) @db.Decimal(10, 3)
  minStock         Decimal         @default(0) @db.Decimal(10, 3)
  costPrice        Decimal?        @db.Decimal(10, 2)
  salePrice        Decimal?        @db.Decimal(10, 2)
  visibleInCatalog Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  movements         StockMovement[]
  saleItems         SaleItem[]
  tragoIngredientes TragoBotella[]
  botellaActiva     BotellaActiva?
  ordenItems        OrdenItem[]
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id])
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  type      MovementType
  quantity  Decimal      @db.Decimal(10, 3)
  unitCost  Decimal?     @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime     @default(now())
}

model Sale {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  subtotal      Decimal       @db.Decimal(10, 2) @default(0)
  discount      Decimal       @db.Decimal(10, 2) @default(0)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(EFECTIVO)
  notes         String?
  createdAt     DateTime      @default(now())
  items         SaleItem[]
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId Int?
  product   Product? @relation(fields: [productId], references: [id])
  tragoId   Int?
  trago     Trago?   @relation(fields: [tragoId], references: [id])
  nombre    String   @default("")
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
}

model Trago {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  salePrice    Decimal?       @db.Decimal(10, 2)
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  ingredientes TragoBotella[]
  saleItems    SaleItem[]
}

model BotellaActiva {
  id         Int      @id @default(autoincrement())
  productId  Int      @unique
  product    Product  @relation(fields: [productId], references: [id])
  capacidad  Decimal  @db.Decimal(10, 3)
  restante   Decimal  @db.Decimal(10, 3)
  alertaOz   Decimal  @db.Decimal(10, 3) @default(3)
  abiertaEn  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TragoBotella {
  id        Int     @id @default(autoincrement())
  tragoId   Int
  trago     Trago   @relation(fields: [tragoId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  cantidad  Decimal @db.Decimal(10, 3)
}

enum MesaStatus {
  ABIERTA
  CERRADA
}

model Mesa {
  id        Int        @id @default(autoincrement())
  numero    Int        @unique
  nombre    String?
  status    MesaStatus @default(ABIERTA)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comandas  Comanda[]
}

model Comanda {
  id        Int           @id @default(autoincrement())
  mesaId    Int
  mesa      Mesa          @relation(fields: [mesaId], references: [id])
  userId    Int
  notes     String?
  status    MesaStatus    @default(ABIERTA)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     ComandaItem[]
}

model ComandaItem {
  id        Int      @id @default(autoincrement())
  comandaId Int
  comanda   Comanda  @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  productId Int?
  tragoId   Int?
  nombre    String
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
}

enum OrdenStatus {
  PENDIENTE
  RECIBIDA
  CANCELADA
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  ordenes   OrdenCompra[]
}

model OrdenCompra {
  id           Int         @id @default(autoincrement())
  proveedorId  Int?
  proveedor    Proveedor?  @relation(fields: [proveedorId], references: [id])
  userId       Int
  status       OrdenStatus @default(PENDIENTE)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrdenItem[]
}

model OrdenItem {
  id          Int         @id @default(autoincrement())
  ordenId     Int
  orden       OrdenCompra @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product     @relation(fields: [productId], references: [id])
  quantity    Decimal     @db.Decimal(10, 3)
  unitCost    Decimal?    @db.Decimal(10, 2)
  received    Decimal     @db.Decimal(10, 3) @default(0)
}
